# OmniRom Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Application
# ============================================================================
DEBUG=true
LOG_LEVEL=INFO

# Host and port for the FastAPI server
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================================
# Redis Cache (optional)
# ============================================================================
# Set REDIS_URL to enable caching. Examples:
#   Redis:    redis://localhost:6379/0
#   Valkey:   valkey://localhost:6379/0
#   Redis with auth: redis://:password@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 7 days)
# CACHE_TTL=604800

# ============================================================================
# Rate Limiting (optional - not yet implemented)
# ============================================================================
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60

# ============================================================================
# File Upload Limits
# ============================================================================
# MAX_FILE_SIZE_MB=10
# MAX_FILE_LINES=10000
