# OmniRom Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Application
# ============================================================================
DEBUG=false
LOG_LEVEL=INFO

# Host and port for the FastAPI server
# Note: Render provides $PORT environment variable automatically
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================================
# Redis Cache (optional)
# ============================================================================
# Leave REDIS_URL blank to disable caching (service will work without it)
# 
# To enable caching on Render, use an external Redis service like Aiven Valkey:
# 1. Create a free Aiven Valkey account: https://aiven.io/valkey
# 2. Get your connection string from Aiven console
# 3. Set REDIS_URL to your connection string
#
# Examples:
#   Aiven Valkey: rediss://username:password@host:port
#   Redis:       redis://localhost:6379/0
#   Valkey:      valkey://localhost:6379/0
#   Redis with auth: redis://:password@localhost:6379/0
REDIS_URL=

# Cache TTL in seconds (default: 7 days = 604800)
# CACHE_TTL=604800

# ============================================================================
# Rate Limiting (optional)
# ============================================================================
# Requests per window (set to 0 or comment out to disable)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# File Upload Limits
# ============================================================================
# MAX_FILE_SIZE_MB=10
MAX_FILE_LINES=200
